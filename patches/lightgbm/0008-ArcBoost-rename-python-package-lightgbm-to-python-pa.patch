 # coding: utf-8
-"""LightGBM, Light Gradient Boosting Machine.
+"""ArcBoost — gradient boosting with first-class circular feature splits.
 
-Contributors: https://github.com/microsoft/LightGBM/graphs/contributors.
+A fork of LightGBM v4.6.0 (https://github.com/microsoft/LightGBM) that adds
+the `circular` feature type for splits over arcs `[a, b] mod period` rather
+than linear thresholds. Pass `circular_feature` (and optionally
+`circular_period`, `max_bin_circular`) in the parameter dict to opt in.
+
+Upstream LightGBM contributors: https://github.com/microsoft/LightGBM/graphs/contributors.
 """
 
 from pathlib import Path
@@ -29,6 +34,10 @@ except ImportError:
 _version_path = Path(__file__).absolute().parent / "VERSION.txt"
 if _version_path.is_file():
     __version__ = _version_path.read_text(encoding="utf-8").strip()
+else:
+    # Fallback when packaged without VERSION.txt (e.g., source checkouts that
+    # haven't been built through scikit-build-core yet).
+    __version__ = "0.1.0.dev0"
 
