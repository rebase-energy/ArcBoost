 include/LightGBM/dataset_loader.h |  2 ++
 src/io/bin.cpp                    | 45 +++++++++++++++++++++++++
 src/io/dataset_loader.cpp         | 55 +++++++++++++++++++++++++++++--
 3 files changed, 100 insertions(+), 2 deletions(-)

