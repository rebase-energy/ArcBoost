+  /*! \brief ArcBoost: feature indices flagged as circular by config_.circular_feature */
+  std::unordered_set<int> circular_features_;
   /*! \brief Whether to store raw feature values */
   bool store_raw_;
 };
diff --git a/src/io/bin.cpp b/src/io/bin.cpp
index 3d84599e..d77765fb 100644
--- a/src/io/bin.cpp
+++ b/src/io/bin.cpp
@@ -1069,4 +1069,49 @@ namespace LightGBM {
 
   #endif  // USE_CUDA
 
+// ArcBoost: initialize a BinMapper as a circular feature.
+//
+// The arc-bin grid is uniform on [0, period) with `num_bin` bins (or
+// `num_bin - 1` real bins plus one NaN bin when missing_type == NaN). No
+// sample data is needed — the binning is purely a function of the period
+// and bin count, so we skip the FindBin sample-based machinery entirely.
+//
+// Fields populated:
+//   - bin_type_         = BinType::CircularBin
+//   - num_bin_          = num_bin
+//   - missing_type_     = caller-provided
+//   - circular_period_  = period (used by ValueToBin)
+//   - default_bin_      = ValueToBin(0.0)
+//   - most_freq_bin_    = default_bin_
+//   - is_trivial_       = (num_bin <= 1)
+//   - min_val_ / max_val_ = 0 / period (for serialization parity with numeric)
+//   - bin_upper_bound_  = empty (circular uses modular indexing, no thresholds)
+//   - categorical_2_bin_ / bin_2_categorical_ = empty
+//   - sparse_rate_      = 0 (no sample data to compute it from)
+void BinMapper::InitAsCircular(int num_bin, double period, MissingType missing_type) {
+  if (period <= 0.0) {
+    Log::Fatal("InitAsCircular: circular_period must be > 0, got %.6g", period);
+  }
+  if (num_bin <= 1) {
+    Log::Fatal("InitAsCircular: num_bin must be > 1 (got %d) — a single-bin "
+               "circular feature carries no information", num_bin);
+  }
+  bin_type_ = BinType::CircularBin;
+  num_bin_ = num_bin;
+  missing_type_ = missing_type;
+  circular_period_ = period;
+  is_trivial_ = false;
+  sparse_rate_ = 0.0;
+  min_val_ = 0.0;
+  max_val_ = period;
+  bin_upper_bound_.clear();
+  categorical_2_bin_.clear();
+  bin_2_categorical_.clear();
+  // Now that all fields driving ValueToBin are set, compute default_bin_ and
+  // most_freq_bin_. For a uniform circular distribution, the choice doesn't
+  // matter for correctness — pick the bin containing 0.0.
+  default_bin_ = ValueToBin(0.0);
+  most_freq_bin_ = default_bin_;
+}
+
 }  // namespace LightGBM
diff --git a/src/io/dataset_loader.cpp b/src/io/dataset_loader.cpp
index 9c8a0417..a8d40608 100644
--- a/src/io/dataset_loader.cpp
+++ b/src/io/dataset_loader.cpp
@@ -188,6 +188,40 @@ void DatasetLoader::SetHeader(const char* filename) {
       }
     }
   }
+  // ArcBoost: parse config_.circular_feature with the same name:/index syntax
+  // as categorical_feature. The set populated here is consumed in
+  // ConstructFromSampleData / ConstructFromMultipleData (this file) where
+  // BinMappers are instantiated — features in this set get InitAsCircular()
+  // instead of FindBin() and end up with bin_type_ == BinType::CircularBin.
+  if (config_.circular_feature.size() > 0) {
+    if (Common::StartsWith(config_.circular_feature, name_prefix)) {
+      std::string names = config_.circular_feature.substr(name_prefix.size());
+      for (auto name : Common::Split(names.c_str(), ',')) {
+        if (name2idx.count(name) > 0) {
+          int tmp = name2idx[name];
+          circular_features_.emplace(tmp);
+        } else {
+          Log::Fatal("Could not find circular_feature %s in data", name.c_str());
+        }
+      }
+    } else {
+      for (auto token : Common::Split(config_.circular_feature.c_str(), ',')) {
+        int tmp = 0;
+        if (!Common::AtoiAndCheck(token.c_str(), &tmp)) {
+          Log::Fatal("circular_feature is not a number,\n"
+                     "if you want to use a column name,\n"
+                     "please add the prefix \"name:\" to the column name");
+        }
+        circular_features_.emplace(tmp);
+      }
+    }
+  }
+  // ArcBoost: validate that no feature is both circular and categorical.
+  for (int idx : circular_features_) {
+    if (categorical_features_.count(idx) > 0) {
+      Log::Fatal("Feature %d cannot be both categorical_feature and circular_feature.", idx);
+    }
+  }
 }
 
